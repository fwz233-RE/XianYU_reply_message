API_KEY=默认使用通义千问,apikey通过百炼模型平台获取
COOKIES_STR=your_cookies_here
MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_NAME=qwen-max
TOGGLE_KEYWORDS=。
SIMULATE_HUMAN_TYPING=False
# Cookie获取来源: env(手动) / plugin(浏览器插件自动推送)
COOKIE_SOURCE=env
# 插件桥接服务配置（COOKIE_SOURCE=plugin 时生效）
COOKIE_BRIDGE_HOST=127.0.0.1
COOKIE_BRIDGE_PORT=18765
COOKIE_BRIDGE_TOKEN=change_me_cookie_bridge_token
# 多项目/多账号隔离标识，建议每个项目实例唯一
COOKIE_PROJECT_ID=
# 可选：限制仅接收指定账号（通常填写闲鱼 unb）
COOKIE_ACCOUNT_HINT=
# 等待插件Cookie的超时时间（秒）
COOKIE_WAIT_TIMEOUT=300
# 风控刷新时要求Cookie必须变化
COOKIE_REQUIRE_CHANGE=True
# Web UI 服务监听地址
UI_HOST=127.0.0.1
UI_PORT=8765